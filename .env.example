# Environment Configuration for THE SAIYANS Backend
# Copy this file to .env and update with your actual values

# Server Configuration
PORT=3001
NODE_ENV=development

# JWT Configuration - GENERATE A MORE SECURE ONE FOR PRODUCTION
# Run: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))" to generate secure key
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production-make-it-very-long-and-random

# Database Configuration
# For PostgreSQL (recommended for production):
# DATABASE_URL=postgresql://username:password@localhost:5432/saiyans
# For local development without Docker:
# DATABASE_URL=postgresql://postgres:password@localhost:5432/saiyans

# CORS Configuration (comma-separated origins)
# For production, update with your deployed domain
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001,http://localhost:5500,http://localhost:5501,http://127.0.0.1:5500,http://127.0.0.1:5501,https://iceman-rgb.github.io,https://yourdomain.com

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
AUTH_RATE_LIMIT_MAX=5

# Optional: For production deployment with HTTPS
# SSL_KEY_PATH=/etc/ssl/private/key.pem
# SSL_CERT_PATH=/etc/ssl/certs/cert.pem

# Admin Configuration
# Set this to true for the first user created to make them admin
FIRST_USER_IS_ADMIN=false

# Notes:
# - This backend now uses PostgreSQL instead of SQLite
# - PostgreSQL is required for cloud deployments (Render, Railway, etc.)
# - For local development, install PostgreSQL: https://www.postgresql.org/download/
# - Create database: createdb saiyans
# - Update DATABASE_URL with your local credentials